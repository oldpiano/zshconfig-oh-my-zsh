alias sll='sudo ls -AlF --color '
alias grep='grep -I --colour=always '
alias lsop='lsof -nP -i | grep LISTEN'
alias psgrep='ps aux | grep -i '
alias hgrep='history | grep -i '
alias pst='pstree -aAUhnlp'
alias du1='du -h -d 1 | sort -h'
alias via='vim ~/.oh-my-zsh/lib/alias'
alias mtu_500="sudo ifconfig $(route get google.com | grep --color=no interface | awk '{print $2}') mtu 500"
alias mtu_reset="sudo ifconfig $(route get google.com | grep --color=no interface | awk '{print $2}') mtu 1500"
alias c='cat '
alias v='vim '
alias t='tail -f '
